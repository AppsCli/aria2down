+// aria2down public API extensions ----------------------------------------
+//
+// Out-of-tree additions backing the ARIA2DOWN_HAS_* feature macros in
+// <aria2/aria2.h>. Each function is a thin shim over an existing
+// internal RequestGroupMan method: the work the upstream JSON-RPC
+// handlers already do, now reachable through the public libaria2 API
+// so the FFI shim can call into it without spinning up an RPC server.
+
+std::vector<A2Gid> getReservedDownload(Session* session)
+{
+  auto& e = session->context->reqinfo->getDownloadEngine();
+  std::vector<A2Gid> res;
+  for (const auto& group : e->getRequestGroupMan()->getReservedGroups()) {
+    res.push_back(group->getGID());
+  }
+  return res;
+}
+
+std::vector<A2Gid> getDownloadResults(Session* session)
+{
+  auto& e = session->context->reqinfo->getDownloadEngine();
+  std::vector<A2Gid> res;
+  for (const auto& dr : e->getRequestGroupMan()->getDownloadResults()) {
+    res.push_back(dr->gid->getNumericId());
+  }
+  return res;
+}
+
+int removeDownloadResult(Session* session, A2Gid gid)
+{
+  auto& e = session->context->reqinfo->getDownloadEngine();
+  return e->getRequestGroupMan()->removeDownloadResult(gid) ? 0 : -1;
+}
+
+void purgeDownloadResult(Session* session)
+{
+  auto& e = session->context->reqinfo->getDownloadEngine();
+  e->getRequestGroupMan()->purgeDownloadResult();
+}
+
 } // namespace aria2
