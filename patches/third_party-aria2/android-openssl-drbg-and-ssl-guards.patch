+#if defined(HAVE_OPENSSL) && defined(__ANDROID__)
+namespace {
+// 直接从 /dev/urandom 抽熵。先用 syscall(SYS_getrandom) 绕过 libc 包装；若
+// SECCOMP 拦截则退到 read("/dev/urandom")。两条路径都不会触发 OpenSSL DRBG。
+int devurandom_bytes_impl(unsigned char* buf, int num)
+{
+  if (num <= 0) return 1;
+  size_t want = static_cast<size_t>(num);
+  size_t got = 0;
+#  ifdef SYS_getrandom
+  while (got < want) {
+    long n = ::syscall(SYS_getrandom, buf + got, want - got, 0);
+    if (n < 0) {
+      if (errno == EINTR) continue;
+      break;
+    }
+    if (n == 0) break;
+    got += static_cast<size_t>(n);
+  }
+  if (got == want) return 1;
+#  endif
+  int fd = ::open("/dev/urandom", O_RDONLY | O_CLOEXEC);
+  if (fd < 0) return 0;
+  while (got < want) {
+    auto n = ::read(fd, buf + got, want - got);
+    if (n < 0) {
+      if (errno == EINTR) continue;
+      break;
+    }
+    if (n == 0) break;
+    got += static_cast<size_t>(n);
+  }
+  ::close(fd);
+  return got == want ? 1 : 0;
+}
+
+int devurandom_status_impl() { return 1; }
+
+RAND_METHOD devurandom_method = {
+    nullptr,                 // seed
+    devurandom_bytes_impl,   // bytes
+    nullptr,                 // cleanup
+    nullptr,                 // add
+    devurandom_bytes_impl,   // pseudorand
+    devurandom_status_impl,  // status
+};
+} // namespace
+#endif // HAVE_OPENSSL && __ANDROID__
+
