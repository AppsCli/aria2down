{
  "manifest_version": 2,
  "name": "aria2down",
  "version": "0.1.0",
  "description": "Send download links to aria2 via JSON-RPC.",
  "permissions": [
    "contextMenus",
    "storage",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "scripts": ["aria2_rpc.js", "background.js"]
  },
  "options_ui": {
    "page": "options.html",
    "browser_style": true
  }
}
